RewriteEngine On
# Deployed under admin/modules/_zts_provisioning (SHARED_PROVISIONING_MODULE_SUBDIR; see DEPLOY.md).

# Keep direct script access available.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route standard Yealink / Fanvil cfg filenames to router (*.boot not routed — 404).
RewriteRule ^[Ff]0[0-9A-Za-z.\-]+\.cfg$ router.php [L,QSA]
RewriteRule ^y0000000000[0-9]{2,3}\.cfg$ router.php [L,QSA]
RewriteRule ^[0-9A-Fa-f]{12}\.cfg$ router.php [L,QSA]
